# ===========================================
# Pet Carte Server - 環境変数設定テンプレート
# ===========================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# -------------------------------------------
# 必須設定
# -------------------------------------------

# データベース接続（ローカル開発用）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pet_carte

# JWT認証シークレット（ランダムな文字列を設定）
JWT_SECRET=your-super-secret-key-change-this

# サーバーポート
PORT=3001

# フロントエンドURL
FRONTEND_URL=http://localhost:5173

# -------------------------------------------
# Supabase設定（本番環境で必須）
# -------------------------------------------

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key（公開キー）
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key（秘密キー - サーバーサイドのみ）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase JWT Secret（Settings > API > JWT Secret）
# 設定するとトークン検証がローカルで完結し、APIレスポンスが高速化
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase Storageバケット名
SUPABASE_STORAGE_BUCKET=uploads

# 個人情報ファイル用の非公開バケット名
SUPABASE_PRIVATE_STORAGE_BUCKET=secure-uploads

# -------------------------------------------
# PAY.JP決済（オプション - SaaS利用料決済用）
# -------------------------------------------

# PAY.JP Secret Key
# PAYJP_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# PAY.JP Public Key
# PAYJP_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx

# PAY.JP Webhook Token（Webhook URLごとに発行される検証トークン）
# PAYJP_WEBHOOK_TOKEN=whsec_xxxxxxxxxxxxx

# -------------------------------------------
# メール送信（オプション - 通知機能用）
# -------------------------------------------

# SMTPホスト
# SMTP_HOST=smtp.gmail.com

# SMTPポート
# SMTP_PORT=587

# SMTPユーザー名（メールアドレス）
# SMTP_USER=your-email@gmail.com

# SMTPパスワード（Gmailの場合はアプリパスワード）
# SMTP_PASSWORD=your-app-password

# 送信元アドレス
# SMTP_FROM=noreply@your-domain.com

# -------------------------------------------
# Google Calendar連携（オプション）
# -------------------------------------------

# Google OAuth Client ID
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Google OAuth Client Secret
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# Google OAuth Redirect URI
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/google-calendar/callback

# -------------------------------------------
# Google Gemini API（オプション - AI機能用）
# -------------------------------------------

# Gemini API Key
# GEMINI_API_KEY=AIzaSy...

# -------------------------------------------
# Vercel Cron Jobs（本番環境で設定）
# -------------------------------------------

# Cronエンドポイント認証用シークレット（ランダムな文字列を設定）
# CRON_SECRET=your-cron-secret-change-this

# -------------------------------------------
# Sentry（エラー監視）
# -------------------------------------------

# Sentry DSN（サーバー側）
# SENTRY_DSN=https://xxx@o0.ingest.sentry.io/000000

# フロントエンドのソースマップアップロード用（Viteビルド時に参照）
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=blink-pet
# SENTRY_PROJECT=blink-frontend

# -------------------------------------------
# Resend（メール送信 - Resend利用時）
# -------------------------------------------

# Resend API Key
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# 送信元アドレス
# RESEND_FROM=Blink <noreply@your-domain.com>

# -------------------------------------------
# LIFF / LINE Mini App
# -------------------------------------------

# LIFF ID（LINE Mini Appのリンク生成に使用）
# LIFF_ID=1234567890-abcdefgh

# LINE Login Channel ID（LIFFのIDトークン検証に使用）
# LINE_LOGIN_CHANNEL_ID=1234567890

# 開発時のみ raw lineUserId を許可する場合に明示的に有効化
# ALLOW_INSECURE_LIFF_DEV_AUTH=false

# -------------------------------------------
# トライアル用LINE公式アカウント
# -------------------------------------------

# トライアル店舗が共用するLINEチャネル
# TRIAL_LINE_CHANNEL_ID=
# TRIAL_LINE_CHANNEL_SECRET=
# TRIAL_LINE_CHANNEL_ACCESS_TOKEN=

# -------------------------------------------
# 暗号化キー
# -------------------------------------------

# データ暗号化キー（32バイト以上のランダム文字列）
# ENCRYPTION_KEY=

# -------------------------------------------
# Clarity Heatmap エクスポート（オプション）
# -------------------------------------------

# CLARITY_EXPORT_NUM_OF_DAYS=1
# CLARITY_EXPORT_SYNC_INTERVAL_MINUTES=60
# CLARITY_EXPORT_MAX_AGE_HOURS=24
# CLARITY_EXPORT_DIMENSION1=
# CLARITY_EXPORT_DIMENSION2=
# CLARITY_EXPORT_DIMENSION3=
# CLARITY_EXPORT_API_URL=
# CLARITY_EXPORT_API_TOKEN=
# CLARITY_EXPORT_TIMEOUT_MS=15000

# -------------------------------------------
# UXレポート（オプション）
# -------------------------------------------

# UXレポート出力ディレクトリ
# UX_REPORT_DIR=

# -------------------------------------------
# 注意: LINE Messaging APIは店舗ごとにデータベースで管理
# -------------------------------------------
# LINE認証情報は環境変数ではなく、storesテーブルに保存します:
# - line_channel_id
# - line_channel_secret
# - line_channel_access_token
