# ===========================================
# Blink Client - 環境変数設定テンプレート
# ===========================================
# このファイルを .env.local にコピーして値を設定してください
# cp .env.example .env.local

# -------------------------------------------
# 必須設定
# -------------------------------------------

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key（公開キー）
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# APIサーバーURL（末尾に /api を含む）
# 開発環境: http://localhost:3001/api
# 本番環境: /api（同一ドメイン）
VITE_API_URL=/api

# -------------------------------------------
# LIFF / LINE Mini App
# -------------------------------------------

# LIFF ID（LINE Mini Appの初期化に使用）
VITE_LIFF_ID=

# -------------------------------------------
# オプション設定
# -------------------------------------------

# フロントエンドURL（OAuth コールバック等に使用）
# 開発環境: http://localhost:5173
# 本番環境: https://your-domain.com
# VITE_FRONTEND_URL=http://localhost:5173

# Sentry DSN（エラー監視）
# VITE_SENTRY_DSN=https://xxx@o0.ingest.sentry.io/000000

# Microsoft Clarity プロジェクトID（ヒートマップ分析）
# VITE_CLARITY_PROJECT_ID=
